function api(action,params){
  var body=Object.assign({action:action},params||{});

  /* Contexte Google Apps Script (web app déployée sur script.google.com) */
  if(IS_GAS){
    return new Promise(function(res,rej){
      var done=false;
      var _t=setTimeout(function(){if(!done){done=true;rej(new Error('Délai dépassé'));}},90000);
      google.script.run
        .withSuccessHandler(function(r){
          clearTimeout(_t);if(done)return;done=true;
          if(typeof r==='string'){try{r=JSON.parse(r);}catch(e){rej(new Error('Réponse invalide'));return;}}
          if(r&&r.ok===false&&r.message){rej(new Error(r.message));return;}
          res(r);
        })
        .withFailureHandler(function(e){
          clearTimeout(_t);if(!done){done=true;rej(new Error(e.message||String(e)));}
        })
        .apiFromClient(body);
    });
  }

  /* Contexte externe (Netlify, GitHub Pages, etc.) — JSONP */
  return new Promise(function(res,rej){
    var cb='_pf_'+(++_cbId)+'_'+Date.now(),done=false;
    var tid=setTimeout(function(){
      if(done)return;done=true;cleanup();
      rej(new Error('Timeout — vérifiez que le serveur GAS est déployé en accès "Tout le monde"'));
    },35000);

    window[cb]=function(r){
      if(done)return;done=true;clearTimeout(tid);cleanup();
      if(typeof r==='string'){try{r=JSON.parse(r);}catch(e){rej(new Error('Réponse invalide'));return;}}
      if(r&&r.ok===false&&r.message){rej(new Error(r.message));return;}
      res(r);
    };

    function cleanup(){
      try{delete window[cb];}catch(e){window[cb]=undefined;}
      var el=document.getElementById(cb);
      if(el&&el.parentNode)el.parentNode.removeChild(el);
    }

    var sc=document.createElement('script');
    sc.id=cb;
    sc.src=GAS_URL
      +'?data='+encodeURIComponent(JSON.stringify(body))
      +'&callback='+cb
      +'&_t='+Date.now();
    sc.onerror=function(){
      if(done)return;done=true;clearTimeout(tid);cleanup();
      rej(new Error('Erreur réseau — impossible de joindre le serveur GAS'));
    };
    document.head.appendChild(sc);
  });
}

